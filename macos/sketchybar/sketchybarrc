# date
sketchybar --add item date right                                    \
           --set      date icon=󱨰                                   \
                           icon.color=0xFFFFFFFF                  \
                           label="$(date '+%a %b %d')"              \
                           script='./plugins/date.sh'               \
                           update_freq=10

# weather
sketchybar --add item weather right                                 \
           --set      weather icon=A                                \
                              icon.color=0xFFFFFFFF                  \
                              label="--°F"                          \
                              script='./plugins/weather.sh'         \
                              update_freq=60                        \
			      click_script="open $WEATHER_URL"


# network (wifi/ethernet/vpn)
sketchybar --add item network right                                  \
           --set      network icon=󰤨                                 \
                              icon.color=0xFFFFFFFF                   \
                              icon.font="Hack Nerd Font:Propo:18.0"   \
                              label.font="Hack Nerd Font:Propo:18.0"  \
                              label.drawing=off                       \
                              script='./plugins/network.sh'           \
                              update_freq=10
sketchybar --subscribe network wifi_change

# battery
sketchybar --add item battery right                                 \
           --set      battery icon=                                \
                              icon.color=0xFFFFFFFF                  \
                              label="--%"                           \
                              script='./plugins/battery.sh'         \
                              update_freq=20


# imessage unread count
sketchybar --add item imessage right                                 \
           --set      imessage icon=󰍡                                \
                               icon.color=0xFFFFFFFF                  \
                               label.color=0xFFFFFFFF                 \
                               script='./plugins/imessage.sh'        \
                               update_freq=5                         \
                               updates=on                            \
                               drawing=off                           \
                               click_script='open -a Messages'

# whatsapp unread count
sketchybar --add item whatsapp right                                 \
           --set      whatsapp icon=󰖣                                \
                               icon.color=0xFFFFFFFF                  \
                               label.color=0xFFFFFFFF                 \
                               script='./plugins/whatsapp.sh'        \
                               update_freq=5                         \
                               updates=on                            \
                               drawing=off                           \
                               click_script='open -a WhatsApp'


sketchybar --add item title_proxy right                             \
           --set      title_proxy y_offset=100                      \
                                  label="Title"

# bracket groups (semi-transparent dark backgrounds)
sketchybar --add bracket right_group date weather network battery     \
           --set right_group background.color=0xbf000000             \
                             background.corner_radius=10             \
                             background.height=25

# finish config
sketchybar --hotload on
sketchybar --update
