# emacs perspective indicator - dynamically created for each display
sketchybar --add event emacs_persp_update
bash ./plugins/emacs-persp-setup.sh

# emacs org-clock indicator
sketchybar --add event emacs_clock_update
bash ./plugins/emacs-clock-setup.sh

# org-agenda launcher button
sketchybar --add item emacs_agenda left \
           --set emacs_agenda \
             icon=󰃭 \
             icon.color=0xFFFFFFFF \
             icon.padding_left=10 \
             icon.padding_right=10 \
             label.drawing=off \
             background.color=0xbf000000 \
             background.corner_radius=10 \
             background.height=25 \
             click_script='~/.dotfiles/macos/scripts/org-agenda-frame.sh'

# update defaults (flat/transparent style)
sketchybar --default                                                \
                     background.color=0x00000000                    \
                     blur_radius=0                                  \
                     background.corner_radius=0                     \
                     background.height=0                            \
                     icon.padding_left=6                            \
                     icon.padding_right=4                           \
                     label.padding_left=4                           \
                     label.padding_right=10                         \
                     background.padding_left=0                      \
                     background.border_width=0


# ~~ center items ~~

# app title
sketchybar --add event title_change
sketchybar --add item title center                                  \
           --set      title label.padding_left=12                   \
                            label="Title"                           \
                            background.padding_left=0               \
                            icon.font="sketchybar-app-font:Regular:16.0" \
                            icon.padding_left=10                     \
                            icon.padding_right=0                    \
                            script='./plugins/title.sh'             \
                            background.border_color=0x00000000      \
                            update_freq=1                           \
                            label.max_chars=54

sketchybar --subscribe title title_change


# ~~ right items ~~
# yabai layout - dynamically created for each connected display
sketchybar --add event layout_change
bash ./plugins/yabai-layout-setup.sh

