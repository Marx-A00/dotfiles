# -*- mode: sh -*-
# Machine-local secrets for the sketchybar weather item.
#
# Setup:
#   cp weather.env.sh.example weather.env.sh
#   # then fill in the values below
#
# This file (weather.env.sh) is gitignored — the .example is the committed template.

# weatherapi.com API key and the city to query (used by plugins/weather.sh)
KEY="your-weatherapi-com-key"
CITY="Your City"

# URL opened when you click the weather item (used by sketchybarrc)
WEATHER_URL="https://weather.com/"
