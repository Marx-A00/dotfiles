# Primary font. This machine has the VANILLA Iosevka builds installed, not the
# Nerd Font patched ones, so use the real installed family name — verify with:
#   /Applications/Ghostty.app/Contents/MacOS/ghostty +list-fonts
# Nerd-Font icon glyphs still render: Ghostty auto-falls-back to the installed
# "Symbols Nerd Font Mono" for those.
font-family = Iosevka Term Slab
# Other installed monospace families you can swap in (exact names, verified):
#   font-family = Iosevka Fixed Slab            # fixed-width slab
#   font-family = Iosevka Term                  # terminal cut, no slab
#   font-family = JetBrainsMono Nerd Font Mono  # bundled nerd glyphs
#   font-family = FiraCode Nerd Font Mono       # Fira Code + nerd glyphs

# Fallback, used ONLY for glyphs the primary lacks — e.g. the ROMAN DENARIUS
# SIGN (U+10196) in the shell prompt. Big Caslon is one of the few macOS fonts
# that actually has it.
font-family = Big Caslon
